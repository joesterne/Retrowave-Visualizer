{
  "entities": {
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite track or visualizer preset.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "type": { "type": "string", "enum": ["track", "visualizer"], "description": "Type of favorite" },
        "id": { "type": "string", "description": "External ID (Spotify URI, YouTube ID, or visualizer name)" },
        "title": { "type": "string", "description": "Display title" },
        "subtitle": { "type": "string", "description": "Display subtitle (artist, etc.)" },
        "thumbnail": { "type": "string", "description": "Thumbnail URL" },
        "source": { "type": "string", "description": "Source (spotify, youtube, local)" },
        "url": { "type": "string", "description": "Audio or video URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "type", "id", "title", "createdAt"]
    },
    "UserSetting": {
      "title": "UserSetting",
      "description": "User-specific application settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "theme": { "type": "string", "description": "Selected retro theme" },
        "visualizerMode": { "type": "string", "description": "Default visualizer mode" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorites collection"
    },
    "/settings/{userId}": {
      "schema": "UserSetting",
      "description": "User settings document"
    }
  }
}
